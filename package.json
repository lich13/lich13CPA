{
  "name": "lich13cpa",
  "productName": "lich13CPA",
  "private": true,
  "version": "0.1.5",
  "description": "Tauri desktop shell for CLIProxyAPI with local config, auth, and bundled binary flow.",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "npm run tauri:dev",
    "dev:renderer": "vite",
    "app:version:set": "node scripts/set-app-version.mjs",
    "usage:pricing:update": "node scripts/update-usage-pricing.mjs",
    "tauri:prepare:host": "node scripts/prepare-tauri-bundled-binary.mjs",
    "tauri:prepare:mac:arm64": "node scripts/prepare-tauri-bundled-binary.mjs --target aarch64-apple-darwin",
    "tauri:prepare:win:x64": "node scripts/prepare-tauri-bundled-binary.mjs --target x86_64-pc-windows-msvc",
    "tauri:prepare:win:arm64": "node scripts/prepare-tauri-bundled-binary.mjs --target aarch64-pc-windows-msvc",
    "tauri:postprocess:mac:dmg": "bash scripts/postprocess-macos-dmg.sh src-tauri/target/aarch64-apple-darwin/release/bundle/dmg lich13CPA",
    "tauri:dev": "npm run tauri:prepare:host && tauri dev",
    "tauri:build": "npm run tauri:build:mac:arm64",
    "tauri:build:debug": "npm run tauri:build:debug:mac:arm64",
    "tauri:build:mac:arm64": "npm run tauri:prepare:mac:arm64 && tauri build --bundles dmg --target aarch64-apple-darwin && npm run tauri:postprocess:mac:dmg",
    "tauri:build:debug:mac:arm64": "npm run tauri:prepare:mac:arm64 && tauri build --debug --target aarch64-apple-darwin",
    "tauri:build:win:x64": "npm run tauri:prepare:win:x64 && tauri build --target x86_64-pc-windows-msvc",
    "tauri:build:win:arm64": "npm run tauri:prepare:win:arm64 && tauri build --target aarch64-pc-windows-msvc",
    "build": "npm run usage:pricing:update && tsc -b && vite build",
    "build:renderer": "npm run usage:pricing:update && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "npm run tauri:dev"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.8"
  },
  "overrides": {
    "axios": "^1.15.0"
  }
}
